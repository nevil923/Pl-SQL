DECLARE
    feet NUMBER:=&feet;
    
    cm NUMBER;
    inch NUMBER;
    m NUMBER;
       
    BEGIN
    cm:=(feet*30.48);
    inch:=(feet*12);
    m:=(feet*0.3048);
    DBMS_OUTPUT.PUT_LINE('feet to cm='||cm);
    DBMS_OUTPUT.PUT_LINE('feet to inch='||inch);
    DBMS_OUTPUT.PUT_LINE('feet to m='||m);
   
    END;
    /
